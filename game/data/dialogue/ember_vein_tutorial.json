{
  "scene_id": "ember_vein_tutorial",
  "entries": [
    {
      "id": "ember_vein_tutorial_001",
      "speaker": "edren",
      "lines": [
        "Hold."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_002",
      "speaker": "edren",
      "lines": [
        "No marks. No signs of a fight. They just... stopped."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_003",
      "speaker": "cael",
      "lines": [
        "They didn't die fighting. They died feeling something."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_004",
      "speaker": "edren",
      "lines": [
        "There'll be more."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_005",
      "speaker": "cael",
      "lines": [
        "You say that like you've seen it before."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_006",
      "speaker": "edren",
      "lines": [
        "I haven't. That's what worries me."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_007",
      "speaker": "cael",
      "lines": [
        "This one was writing home."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_008",
      "speaker": "cael",
      "lines": [
        "He didn't finish."
      ],
      "condition": null,
      "animations": [
        {
          "who": "cael",
          "anim": "head_down",
          "when": "before_line_0"
        }
      ],
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_009",
      "speaker": "edren",
      "lines": [
        "They were trying to get out."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_010",
      "speaker": "cael",
      "lines": [
        "Some of them. The ones by the Pendulum chamber weren't\ntrying to get anywhere. They just sat down and let it happen."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_011",
      "speaker": "edren",
      "lines": [
        "\"The growths drink deep — even stale water wakes them\nfor a spell.\" Miners were using water on the ley crystals."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_012",
      "speaker": "edren",
      "lines": [
        "Could be useful."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_013",
      "speaker": "edren",
      "lines": [
        "This wasn't built by miners."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_014",
      "speaker": "cael",
      "lines": [
        "This wasn't built by anyone we'd recognize."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_015",
      "speaker": "cael",
      "lines": [
        "Look at this. Whatever they built down here, that\nobject was at the center of it."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_016",
      "speaker": "edren",
      "lines": [
        "The figures aren't worshipping. Look at their posture."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_017",
      "speaker": "cael",
      "lines": [
        "They're bowing under weight. Like they're holding\nsomething up."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_018",
      "speaker": "cael",
      "lines": [
        "Seven of them. Arranged like the mural."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_019",
      "speaker": "edren",
      "lines": [
        "They arranged themselves. Look — no drag marks."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_020",
      "speaker": "cael",
      "lines": [
        "They walked in, sat down, and gave up."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_021",
      "speaker": "edren",
      "lines": [
        "We can't leave it here. If the Compact finds it—"
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_022",
      "speaker": "cael",
      "lines": [
        "Don't."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_023",
      "speaker": "cael",
      "lines": [
        "Something about this place. I can feel it."
      ],
      "condition": null,
      "animations": [
        {
          "who": "cael",
          "anim": "bubble_exclaim",
          "when": "before_line_0"
        }
      ],
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_024",
      "speaker": "edren",
      "lines": [
        "We don't have a choice. We report to Valdris.\nWhatever this is, the court needs to know."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_025",
      "speaker": "cael",
      "lines": [
        "Something heard that."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": [
        {
          "line": 0,
          "id": "ley_surge"
        }
      ]
    },
    {
      "id": "ember_vein_tutorial_026",
      "speaker": "edren",
      "lines": [
        "Compact soldiers. Move."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_027",
      "speaker": "edren",
      "lines": [
        "It's protecting the chamber. Or keeping us in."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_028",
      "speaker": "cael",
      "lines": [
        "Same result either way. Ready?"
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_029",
      "speaker": "edren",
      "lines": [
        "This way. The soldiers are above us, not ahead."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_030",
      "speaker": "cael",
      "lines": [
        "You hope."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_031",
      "speaker": "cael",
      "lines": [
        "Edren. Those murals. The figures weren't holding the\nPendulum up. They were holding something back."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_032",
      "speaker": "edren",
      "lines": [
        "I saw."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_033",
      "speaker": "cael",
      "lines": [
        "Despair. As a weapon. Or as a... state of being.\nSomething those builders understood and we don't."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "ember_vein_tutorial_034",
      "speaker": "edren",
      "lines": [
        "Let's make sure we don't have to understand it.\nCome on."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    }
  ]
}
