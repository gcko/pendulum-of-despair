      "choice": null,
      "sfx": null
    },
    {
      "id": "scene_30_liras_trial_the_unfinished_forge_002",
      "speaker": "perfect_machine",
      "lines": [
        "Almost. Try again."
      ],
      "condition": null,
      "animations": null,
      "choice": null,
      "sfx": null
    },
    {
      "id": "scene_30_liras_trial_the_unfinished_forge_003",
      "speaker": "lira",
      "lines": [
        "I cannot fix you. I could not fix him. That was never",
        "my job."
