# EditorConfig is awesome: http://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# 2 space indentation for web stack
[*.{ts,tsx,js,jsx,json,yml,yaml,html}]
indent_style = space
indent_size = 2

[*.{md,rst}]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# GDScript: tabs per Godot convention
[*.gd]
indent_style = tab
indent_size = 4

# Godot scene/resource files
[*.{tscn,tres}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
