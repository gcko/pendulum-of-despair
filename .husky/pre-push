#!/usr/bin/env bash
set -euo pipefail

# --- Beads (bd) pre-push hook ---
if command -v bd >/dev/null 2>&1 && [ -d .beads ]; then
    BD_GIT_HOOK=1 bd hooks run pre-push "$@" || true
fi

GATE_DIR="scripts/quality-gates"

# === QUALITY GATE D: Cross-file ID uniqueness scan ===
echo "=== Pre-push: Cross-file ID uniqueness ==="
python3 "$GATE_DIR/check_id_uniqueness.py"

# === QUALITY GATE E: Stale-count scan ===
echo "=== Pre-push: Stale-count scan ==="
python3 "$GATE_DIR/check_stale_counts.py"

# === QUALITY GATE F: Scene file reference validation ===
echo "=== Pre-push: Scene reference validation ==="
python3 "$GATE_DIR/check_scene_refs.py"

# === QUALITY GATE G: GUT unit tests ===
# Run all GUT tests headless. Requires Godot binary on PATH or at
# /Applications/Godot.app (macOS). Skip gracefully if Godot not found.
GODOT_BIN=""
if command -v godot >/dev/null 2>&1; then
    GODOT_BIN="godot"
elif [ -x "/Applications/Godot.app/Contents/MacOS/Godot" ]; then
    GODOT_BIN="/Applications/Godot.app/Contents/MacOS/Godot"
fi

if [ -n "$GODOT_BIN" ] && [ -f "game/addons/gut/gut_cmdln.gd" ]; then
    echo "=== Pre-push: GUT tests ==="
    TEST_OUTPUT=$("$GODOT_BIN" --headless --path game/ -s addons/gut/gut_cmdln.gd 2>&1)
    FAILING=$(echo "$TEST_OUTPUT" | grep "^Failing Tests" | awk '{print $NF}' || true)
    if [ -n "$FAILING" ] && [ "$FAILING" != "0" ]; then
        echo "$TEST_OUTPUT" | tail -30
        echo "GUT tests FAILED ($FAILING failing). Fix tests before pushing."
        exit 1
    fi
    PASSING=$(echo "$TEST_OUTPUT" | grep "^Passing Tests" | awk '{print $NF}' || true)
    echo "GUT tests passed ($PASSING passing)."
else
    echo "=== Pre-push: GUT tests SKIPPED (Godot not found) ==="
fi

echo "=== All pre-push quality gates passed ==="
