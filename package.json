{
  "name": "pendulum-of-despair",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:shared": "pnpm --filter @pendulum/shared run build",
    "predev:server": "pnpm run build:shared",
    "dev:server": "pnpm --filter @pendulum/server dev",
    "predev:client": "pnpm run build:shared",
    "dev:client": "pnpm --filter @pendulum/client dev",
    "pretest": "pnpm run build:shared",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm -r run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
