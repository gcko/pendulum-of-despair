# gdlint configuration for Pendulum of Despair
# Matches project coding standards from verification-checklists.md

# Naming conventions
function-name: "([a-z][a-z0-9_]*)|(_[a-z][a-z0-9_]*)"
class-name: "[A-Z][a-zA-Z0-9]*"
sub-class-name: "[A-Z][a-zA-Z0-9]*"
signal-name: "[a-z][a-z0-9_]*"
class-variable-name: "([a-z][a-z0-9_]*)|(_[a-z][a-z0-9_]*)"
function-variable-name: "([a-z][a-z0-9_]*)|(_[a-z][a-z0-9_]*)"
function-argument-name: "([a-z][a-z0-9_]*)|(_[a-z][a-z0-9_]*)"
constant-name: "[A-Z][A-Z0-9_]*"
enum-name: "[A-Z][a-zA-Z0-9]*"
enum-element-name: "[A-Z][A-Z0-9_]*"
load-constant-name: "([A-Z][a-zA-Z0-9]*)|([A-Z][A-Z0-9_]*)"

# Script ordering: constants before enums (matches existing autoloads)
class-definitions-order:
  - tools
  - classnames
  - extends
  - docstrings
  - signals
  - consts
  - enums
  - staticvars
  - exports
  - pubvars
  - prvvars
  - onreadypubvars
  - onreadyprvvars
  - others

# Limits
max-line-length: 120
max-file-lines: 400
max-function-length: 60
max-returns: 8
max-branches: 12
max-local-variables: 15
# Raised from 20 to 40 — test files need many test_ methods
max-public-methods: 40
