# Copy this to .env and fill in your values
# NEVER commit your actual .env file

# Port the Express server listens on
PORT=3000

# REQUIRED in production: a long, random secret for signing JWTs
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production

# Path to the SQLite database file
# Use :memory: for in-memory testing only (data is lost on restart)
DB_PATH=./game.db

# Allowed CORS origin (set to your frontend URL in production)
# Use * for development (allow all origins)
CORS_ORIGIN=*
